# Gitea Configuration
GITEA_DOMAIN=git.yourdomain.com
GITEA_ROOT_URL=https://git.yourdomain.com/
GITEA_SSH_DOMAIN=git.yourdomain.com
GITEA_SSH_PORT=2222

# Database Configuration
POSTGRES_PASSWORD=change_this_to_a_secure_password

# Cloudflare Tunnel Token
# Get this from your Cloudflare Zero Trust dashboard after creating a tunnel
TUNNEL_TOKEN=your_tunnel_token_here
