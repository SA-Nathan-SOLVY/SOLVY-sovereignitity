# SOLVY Metrics Server — Environment Configuration
# Copy this file to .env and fill in your values

# Server port
PORT=3000

# Database
# SQLite (development / small scale):
DATABASE_URL=sqlite:./data/solvy.sqlite
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:pass@localhost:5432/solvy

# Security
# Generate a strong random string for production:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=change-me-in-production-generate-a-strong-random-string

# Member ID hash salt — prevents rainbow table attacks on memberIdHash
# Must match the salt used by aggregationService.js on the client
MEMBER_HASH_SALT=solvy_aggregation_salt_2025

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://ebl.beauty,https://www.ebl.beauty,http://localhost:8000,http://localhost:3000

# Email (MailCow SMTP)
# Use direct VPS IP for SMTP — mail.ebl.beauty is Cloudflare-proxied and blocks SMTP traffic
# To fix: create an unproxied A record (e.g., smtp.ebl.beauty → 46.62.235.95) in Cloudflare, then use that
MAILCOW_HOST=46.62.235.95
MAILCOW_USER=noreply@ebl.beauty
MAILCOW_PASS=your-mailcow-password
SUPPORT_EMAIL=support@ebl.beauty
SUPPORT_FROM=noreply@ebl.beauty
# Comma-separated list of recipients for support notifications
SUPPORT_RECIPIENTS=team@solvy.cards,eva@solvy.cards,sean@solvy.cards,smayone@solvy.cards

# Node environment
NODE_ENV=development
