# ─────────────────────────────────────────────────────────────────────────────
# SOLVY Platform Backend — Production Environment
# Copy to .env and fill in real values
# Matches Replit Production: 2 vCPU / 4 GiB RAM / Autoscale
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001

# ── Domains ───────────────────────────────────────────────────────────────────
DOMAIN=ebl.beauty
DOMAIN_CARDS=solvy.cards
DOMAIN_REPLIT=solvy-sovereignitity--smayone.replit.app

# ── Stripe API Keys ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Clerk Authentication ──────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Unit.co Banking ───────────────────────────────────────────────────────────
UNIT_API_TOKEN=v2_...
UNIT_CUSTOMER_ID=...

# ── Persona KYC ───────────────────────────────────────────────────────────────
PERSONA_API_KEY=...

# ── AgentMail Email ───────────────────────────────────────────────────────────
AGENTMAIL_API_KEY=am_...

# ── PostgreSQL Database (matches Replit Production) ───────────────────────────
DATABASE_URL=postgresql://solvy:your_password@localhost:5432/solvy

# ── Frontend URLs (for CORS) ──────────────────────────────────────────────────
FRONTEND_URL_NITTY=https://nitty.ebl.beauty
FRONTEND_URL_DECIDEY=https://decidey.ebl.beauty
FRONTEND_URL_EBL=https://ebl.beauty
FRONTEND_URL_REMITTANCE=https://remittance.ebl.beauty
FRONTEND_URL_CARDS=https://solvy.cards
