# ─────────────────────────────────────────────────────────────────────────────
# SOLVY Unit Integration — Production Environment
# Copy to .env and fill in real values
# Matches Replit Production: 2 vCPU / 4 GiB RAM / Autoscale
# ─────────────────────────────────────────────────────────────────────────────

# Unit.co Configuration
UNIT_API_TOKEN=your_production_token_here
UNIT_API_URL=https://api.s.unit.sh
UNIT_ORG_ID=your_org_id_here

# SOLVY Application
SOLVY_ENV=production
SOLVY_WEBHOOK_SECRET=generate_random_string_here
SOLVY_PORT=3000

# Database
DATABASE_URL=sqlite:/var/www/ebl.beauty/data/solvy.sqlite

# Security
JWT_SECRET=your_jwt_secret_here_min_32_chars

# AgentMail — AI-native email
# Get API key from https://console.agentmail.to
AGENTMAIL_API_KEY=am_...
AGENTMAIL_SUPPORT_INBOX_ID=      # support@solvy.cards inbox
AGENTMAIL_NOREPLY_INBOX_ID=      # noreply@solvy.cards inbox
AGENTMAIL_HELLO_INBOX_ID=        # hello@solvy.cards inbox
AGENTMAIL_WEBHOOK_SECRET=        # for inbound webhook verification

# ── Stripe API Keys ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_RESTRICTED_KEY=rk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Lithic Card Issuing ─────────────────────────────────────────────────────
LITHIC_API_KEY=your_lithic_api_key_here
LITHIC_API_URL=https://sandbox.lithic.com
LITHIC_WEBHOOK_SECRET=your_lithic_webhook_secret_here

# ── DeepSeek AI ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# ── CORS / Domains ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://solvy.cards,https://www.solvy.cards,https://ebl.beauty

# ── Support ─────────────────────────────────────────────────────────────────
SUPPORT_RECIPIENTS=team@solvy.cards,eva@solvy.cards,sean@solvy.cards,smayone@solvy.cards
