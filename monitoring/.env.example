# ============================================================
# SOLVY Ecosystem™ — Monitoring Stack Environment Variables
# ============================================================
# Copy to .env and fill in real values.
# These are loaded by the install-monitoring.sh script and
# referenced by docker-compose.yml and alertmanager.
#
# NEVER commit this file to git.
# ============================================================

# --- Alertmanager Email Configuration ---
SMTP_FROM=alerts@ebl.beauty
SMTP_USER=alerts@ebl.beauty
SMTP_PASS=your-mailcow-smtp-password
ALERT_EMAIL_TO=sean@ebl.beauty

# --- Optional Discord Notifications ---
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# --- SOLVY Backend API Key (for protected endpoint probes) ---
# The blackbox exporter needs this to probe /api/metrics/summary
ADMIN_API_KEY=your-admin-api-key-here
