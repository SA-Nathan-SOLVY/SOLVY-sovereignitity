# ─────────────────────────────────────────────────────────────────────────────
# SOLVY Ecosystem — VPS Production Environment
# Copy to .env and fill in real values
# Matches Replit Production: 2 vCPU / 4 GiB RAM / Autoscale
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains ───────────────────────────────────────────────────────────────────
DOMAIN=ebl.beauty
DOMAIN_CARDS=solvy.cards
DOMAIN_REPLIT=solvy-sovereignitity--smayone.replit.app

# ── Cloudflare Tunnel (optional public access) ────────────────────────────────
# Get this from Cloudflare Zero Trust Dashboard > Networks > Tunnels
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ── PostgreSQL Database (matches Replit Production DB) ────────────────────────
DB_PASSWORD=your_secure_db_password_here
DATABASE_URL=postgresql://solvy:your_secure_db_password_here@db:5432/solvy

# ── Unit.co Banking ───────────────────────────────────────────────────────────
UNIT_API_TOKEN=your_unit_api_token
UNIT_API_URL=https://api.s.unit.sh
UNIT_ORG_ID=your_org_id

# ── SOLVY Application ─────────────────────────────────────────────────────────
SOLVY_ENV=production
SOLVY_PORT=3000
SOLVY_WEBHOOK_SECRET=your_webhook_secret_here

# ── JWT Security ──────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars

# ── AgentMail — AI-native email ───────────────────────────────────────────────
AGENTMAIL_API_KEY=am_...
AGENTMAIL_SUPPORT_INBOX_ID=
AGENTMAIL_NOREPLY_INBOX_ID=
AGENTMAIL_HELLO_INBOX_ID=
AGENTMAIL_WEBHOOK_SECRET=
